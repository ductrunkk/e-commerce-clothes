@model PagedList.IPagedList<model_64132763.EF.USER_ROLE>

@using PagedList.Mvc;
@using PagedList;

@{
    ViewBag.Title = "Quản lý người dùng";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

@section header
{
    Danh sách người dùng
}
@section jsFooter{
    <script>
        var user = {
            init: function () {
                user.registerEvents();
            },
            registerEvents: function () {
                $('.btn-active').off('click').on('click', function (e) {
                    e.preventDefault();
                    var btn = $(this);
                    var id = btn.data('id');
                    $.ajax({
                        url: "/Admin/User_64132763/ChangeStatus",
                        data: { id: id },
                        dataType: "json",
                        type: "POST",
                        success: function (response) {
                            console.log(response);
                            if (response.status == true) {
                                btn.text('ON');
                                btn.removeClass('btn-danger').addClass('btn-success');
                            } else {
                                btn.text('OFF');
                                btn.removeClass('btn-success').addClass('btn-danger');
                            }
                        }
                    });
                });
            }
        }
        user.init();
    </script>

    <script>
        $(document).ready(function () {
            var alertBox = $('#AlertBox');
            if (alertBox.length > 0) {
                alertBox.delay(3000).slideUp(500); // Hiển thị 3 giây và ẩn trong 0.5 giây
            }
        });
    </script>

    $('#AlertBox').removeClass('hide');
    $('#AlertBox').delay(1000).slideUp(500);
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                @using (Html.BeginForm("Index", "User_64132763", FormMethod.Get))
                {
                    <div class="card-tools float-left">
                        <a class="btn btn-primary" href="/Admin/User_64132763/Create">Thêm mới</a>
                    </div>
                    <div class="card-tools float-right">
                        <div class="input-group input-group-sm" style="width: 200px;">
                            <input type="text" name="searchString" value="@ViewBag.SearchString" class="form-control" placeholder="Tìm kiếm">

                            <div class="input-group-append">
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-search"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                }

            </div>
            <!-- /.card-header -->
            <div class="card-body table-responsive p-0">
                <table class="table table-hover text-nowrap">
                    <thead>
                        <tr>
                            <th>Họ</th>
                            <th>Tên</th>
                            <th>Tên đăng nhập</th>
                            <th>Email</th>
                            <th>Số điện thoại</th>
                            <th>Trạng thái</th>
                            <th>Chức năng</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.LAST_NAME</td>
                                <td>@item.FIRST_NAME</td>
                                <td>@item.NAME_USER</td>
                                <td>@item.EMAIL</td>
                                <td>@item.PHONE</td>
                                <td>
                                    <a href="#" class="btn btn-sm btn-active ms-2 @(item.STATUS_SLIDE ? "btn-success" : "btn-danger")" data-id="@item.ID_USER">
                                        @(item.STATUS_SLIDE ? "ON" : "OFF")
                                    </a>
                                </td>
                                <td id="row_@item.ID_USER">
                                    @Html.ActionLink("Sửa", "Edit", new { @id = item.ID_USER }) |
                                    @*@Html.ActionLink("Xem chi tiết", "Details", new { id = item.MaNV }) |*@
                                    @Ajax.ActionLink("Xóa", "Delete", new { @id = item.ID_USER }, new AjaxOptions
                               {
                                   Confirm = "Bạn có muốn xóa bản ghi này không?",
                                   OnComplete = "$('row_" + @item.ID_USER + "').remove()",
                                   HttpMethod = "Delete",

                               })
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <!-- /.card-body -->
            <div class="card-footer">
                <div class="float-start">
                    @Html.PagedListPager(Model, page => Url.Action("Index", new { page, @ViewBag.SearchString }))
                </div>
            </div>
        </div>
        <!-- /.card -->
    </div>
</div>


