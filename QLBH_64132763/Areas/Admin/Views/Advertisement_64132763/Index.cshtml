﻿@model PagedList.IPagedList<model_64132763.EF.ADVERTISEMENT>
@using PagedList.Mvc;
@{
    ViewBag.Title = "Index";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}
@section header
{
    Danh sách Quảng Cáo
}
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                @using (Html.BeginForm("Index", "Advertisement_64132763", FormMethod.Get))
                {
                    <div class="card-tools float-left">
                        @Html.ActionLink("Tạo mới", "Create", "Advertisement_64132763", new { area = "Admin" }, new { @class = "nav-link btn btn-primary" })
                        
                    </div>
                    <div class="card-tools float-right">
                        <div class="input-group input-group-sm" style="width: 200px;">
                            <input type="text" name="searchString" value="@ViewBag.SearchString" class="form-control" placeholder="Tìm kiếm">

                            <div class="input-group-append">
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-search"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                }

            </div>
            <!-- /.card-header -->
            <div class="card-body table-responsive p-0">
                <table class="table table-hover text-nowrap">
                    <thead>
                        <tr>
                            <th>Tiêu đề</th>
                            <th>Ngày đăng</th>
                            <th>Trạng thái</th>
                            <th>Chức năng</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr id="row_@item.ID_ADVERTISEMENT">
                                <td>@item.NAME_ADVERTISEMENT</td>
                                
                                <td>@item.CREATED_DATE</td>
                                <td>
                                    <a href="#" class="btn btn-sm btn-active ms-2 @(item.STATUS_ADVERTISEMENT ? "btn-success" : "btn-danger")" data-id="@item.ID_ADVERTISEMENT">
                                        @(item.STATUS_ADVERTISEMENT ? "ON" : "OFF")
                                    </a>
                                </td>
                                <td id="row_@item.ID_ADVERTISEMENT">
                                    @Html.ActionLink("Sửa", "Edit", new { @id = item.ID_ADVERTISEMENT }) |
                                    @*@Html.ActionLink("Xem chi tiết", "Details", new { id = item.MaNV }) |*@
                                    @Ajax.ActionLink("Xóa", "Delete", new { @id = item.ID_ADVERTISEMENT }, new AjaxOptions
                               {
                                   Confirm = "Bạn có muốn xóa bản ghi này không?",
                                   OnComplete = "$('row_" + @item.ID_ADVERTISEMENT + "').remove()",
                                   HttpMethod = "Delete",

                               })
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <!-- /.card-body -->
            <div class="card-footer">
                <div class="float-start">
                    @Html.PagedListPager(Model, page => Url.Action("Index", new { page, @ViewBag.SearchString }))
                </div>
            </div>
        </div>
        <!-- /.card -->
    </div>
</div>



