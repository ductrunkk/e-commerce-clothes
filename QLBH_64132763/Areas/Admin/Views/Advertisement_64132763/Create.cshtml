@model model_64132763.EF.ADVERTISEMENT

@{
    ViewBag.Title = "Create";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

@section header{
    Tạo mới quảng cáo
}

@section jsFooter{
    <script>
        $('#btnSelectImg').on('click', function (e) {
            e.preventDefault();
            var finder = new CKFinder();
            finder.selectActionFunction = function (url) {
                $('#txtImage').val(url);
            };
            finder.popup();
        })
        ClassicEditor
            .create(document.querySelector('#txtAdvertisement'))
            .catch(error => {
                console.error(error);
            });
    </script>
}
<div class="row d-flex justify-content-center">
    <div class="col-md-7 ">
        <div class="card card-primary">
            <div class="card-header">
                <h3 class="card-title">Nhập thông tin quảng cáo</h3>
            </div>

            <div class="card-body">
                @using (Html.BeginForm("Create", "Advertisement_64132763", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                    <div class="form-group row">
                        @Html.LabelFor(model => model.NAME_ADVERTISEMENT, "Tên quảng cáo", htmlAttributes: new { @class = "control-label col-md-2" })
                        <div class="col-md-10">
                            @Html.EditorFor(model => model.NAME_ADVERTISEMENT, new { htmlAttributes = new { @class = "form-control" } })
                            @Html.ValidationMessageFor(model => model.NAME_ADVERTISEMENT, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="form-group row">
                        @Html.LabelFor(model => model.DESCRIPTIONS_ADVERTISEMENT, "Mô tả", htmlAttributes: new { @class = "control-label col-md-2" })
                        <div class="col-md-10">
                            @Html.EditorFor(model => model.DESCRIPTIONS_ADVERTISEMENT, new { htmlAttributes = new { @class = "form-control" } })
                            @Html.ValidationMessageFor(model => model.DESCRIPTIONS_ADVERTISEMENT, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="form-group row">
                        @Html.LabelFor(model => model.IMAGES, "Ảnh", htmlAttributes: new { @class = "control-label col-md-2" })
                        <div class="col-md-10">
                            @Html.TextBoxFor(model => model.IMAGES, new { htmlAttributes = new { @class = "form-control", @id = "txtImage" }, id = "txtImage" })
                            <a id="btnSelectImg" href="#">Chọn ảnh</a>
                            @Html.ValidationMessageFor(model => model.IMAGES, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="form-group row">
                        @Html.LabelFor(model => model.DETAIL, "Chi tiết quảng cáo", htmlAttributes: new { @class = "control-label col-md-2" })
                        <div class="col-md-10">
                            @Html.TextAreaFor(model => model.DETAIL, new { htmlAttributes = new { @class = "form-control" }, id = "txtAdvertisement" })
                            @Html.ValidationMessageFor(model => model.DETAIL, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="form-group row">
                        @Html.LabelFor(model => model.META_TITLE_PRODUCT, "URL quảng cáo", htmlAttributes: new { @class = "control-label col-md-2" })
                        <div class="col-md-10">
                            @Html.EditorFor(model => model.META_TITLE_PRODUCT, new { htmlAttributes = new { @class = "form-control" } })
                            @Html.ValidationMessageFor(model => model.META_TITLE_PRODUCT, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="form-group row">
                        @Html.LabelFor(model => model.META_DESCRIPTIONS, "URL mô tả", htmlAttributes: new { @class = "control-label col-md-2" })
                        <div class="col-md-10">
                            @Html.EditorFor(model => model.META_DESCRIPTIONS, new { htmlAttributes = new { @class = "form-control" } })
                            @Html.ValidationMessageFor(model => model.META_DESCRIPTIONS, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="form-group row">
                        @Html.LabelFor(model => model.STATUS_ADVERTISEMENT, "Trạng thái", htmlAttributes: new { @class = "control-label col-md-2" })
                        <div class="col-md-10">
                            <div class="form-check pt-2">
                                @Html.CheckBoxFor(model => model.STATUS_ADVERTISEMENT, new { @class = "form-check-input" })
                                <label class="form-check-label" for="@Html.IdFor(model => model.STATUS_ADVERTISEMENT)">Hoạt động</label>
                                @Html.ValidationMessageFor(model => model.STATUS_ADVERTISEMENT, "", new { @class = "text-danger" })
                            </div>
                        </div>
                    </div>

                    <div class="form-group row">
                        @Html.LabelFor(model => model.ID_CATEGORY, "Danh mục", htmlAttributes: new { @class = "control-label col-md-2" })
                        <div class="col-md-10">
                            @Html.DropDownListFor(model => model.ID_CATEGORY, null, new { htmlAttributes = new { @class = "form-control" } })
                            @Html.ValidationMessageFor(model => model.ID_CATEGORY, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="form-group row">
                        @Html.LabelFor(model => model.TAG, "Tag", htmlAttributes: new { @class = "control-label col-md-2" })
                        <div class="col-md-10">
                            @Html.EditorFor(model => model.TAG, new { htmlAttributes = new { @class = "form-control" } })
                            @Html.ValidationMessageFor(model => model.TAG, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="form-group row">
                        <div class="col-md-10 ">
                            <input type="submit" value="Tạo mới" class="btn btn-primary " />
                        </div>
                    </div>
                }

            </div>
            <!-- /.card-body -->
        </div>
        <!-- /.card -->
    </div>
</div>

