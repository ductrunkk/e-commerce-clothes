@model List<QLBH_64132763.Models.CartItem64132763>
@{
    ViewBag.Title = "Payment";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section jsFooter{
    <script src="../Content/assets/js/Controller/CartController.js"></script>
}
<link rel="stylesheet" type="text/css" href="~/Content/assets/styles/single_styles.css">
<link rel="stylesheet" type="text/css" href=" ~/Content/assets/styles/single_responsive.css">
<div class="container single_product_container">
    <div class="row">
        <div class="col-lg-12">
            <h2>Cart</h2>
            @if (Model.Count > 0)
            {
                <table class="table">
                    <thead>
                        <tr>
                            <td>ID Product</td>
                            <td>Name Product</td>
                            <td>Image Product</td>
                            <td>Quantity</td>
                            <td>Price</td>
                            <td>Total</td>
                            <td>Function</td>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Product.ID_PRODUCT</td>
                                <td>@item.Product.NAME_PRODUCT</td>
                                <td><img src="@item.Product.IMAGES" width="100" /></td>
                                <td><input type="text" class="txtQuantity" data-id="@item.Product.ID_PRODUCT" value="@item.QUANTITY" />
                                <td>@item.Product.PRICE_SALE.GetValueOrDefault(0).ToString("N0")</td>
                                <td>@((item.Product.PRICE_SALE.GetValueOrDefault(0) * @item.QUANTITY).ToString("N0"))</td>
                                <td><a href="#" data-id="@item.Product.ID_PRODUCT" class="btn-delete">Xóa</a></td>
                            </tr>
                        }

                    </tbody>
                </table>
                <button id="btnContinue" class="btn">BUY MORE</button>
                <button id="btnUpdate" class="btn">Update</button>
                <button id="btnDeleteAll" class="btn">Delete</button>
                <button id="btnPayment" class="btn">Payment</button>
            }
        </div>
    </div>
    <hr />
    <div class="row">
        <div class="col-lg-12">
            @using (Html.BeginForm("Payment", "Cart_64132763", FormMethod.Post))
            {
                <div class="form-group">
                    <label>Người nhận</label>
                    <input name="SHIP_NAME" class="form-control" />
                </div>
                <div class="form-group">
                    <label>Điện thoại</label>
                    <input name="SHIP_MOBILE" class="form-control" />
                </div>
                <div class="form-group">
                    <label>Địa chỉ</label>
                    <input name="SHIP_ADDRESS" class="form-control" />
                </div>
                <div class="form-group">
                    <label>Email</label>
                    <input name="SHIP_EMAIL" class="form-control" />
                </div>
                <button type="submit" class="btn">Gửi đơn hàng</button>
            }
        </div>
    </div>
</div>

