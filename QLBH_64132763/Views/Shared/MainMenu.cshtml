@model List<model_64132763.EF.MENU>
<div class="main_nav_container">
    <div class="container">
        <div class="row">
            <div class="col-lg-12 text-right">
                <div class="logo_container">
                    <a href="/"  ref="nofollow">colo<span>shop</span></a>
                </div>
                <nav class="navbar">
                    <ul class="navbar_menu">
                        @foreach (var item in Model)
                        {
                            <li><a href="@item.LINK" target="@item.TARGET_MENU">@item.CONTENT</a></li>
                        }
                    </ul>
                    <ul class="navbar_user">
                        <li><a href="#"><i class="fa fa-user" aria-hidden="true"></i></a></li>
                        <li class="checkout">
                            @{Html.RenderAction("HeaderCart", "Home_64132763");}
                        </li>
                        <li class="seach_box">
                            <form action="search" method="get" class="d-flex">
                                <input type="text" id="txtKeyword" name="keyword" placeholder="Keyword"> <input type="submit" value="" />
                            </form>
                            @*<a href="#"><i class="fa fa-search" aria-hidden="true"></i></a>*@
                        </li>
                    </ul>
                    <div class="hamburger_container">
                        <i class="fa fa-bars" aria-hidden="true"></i>
                    </div>
                </nav>
            </div>
        </div>
    </div>
</div>
<script src="~/Content/assets/js/Controller/BaseController.js"></script>